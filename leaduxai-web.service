[Unit]
Description=leaduxAI Web Interface
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/crossposting
ExecStart=/root/crossposting/.venv/bin/python -c "from web_app import app; app.run(host='0.0.0.0', port=5001)"
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target