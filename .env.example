# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # токен бота из @BotFather (бот = админ твоего канала)
TELEGRAM_CHANNEL_CHAT_ID=    # ID твоего канала, куда публиковать карусели (-100...)
NOTIFY_CHAT_ID=              # твой личный chat_id (сюда бот шлёт кнопки одобрения)

# ── Telethon (userbot) ────────────────────────────────────────────────────────
TG_API_ID=                   # с https://my.telegram.org
TG_API_HASH=                 # с https://my.telegram.org
SOURCE_CHANNELS=@channel1,@channel2   # чужие каналы, откуда парсим
SESSION_FILE=/data/tg_parser.session  # Railway: используй persistent volume /data

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=              # https://aistudio.google.com/apikey

# ── Настройки карусели ────────────────────────────────────────────────────────
SLIDE_COUNT=5                # количество слайдов в карусели
MIN_TEXT_LEN=80              # игнорировать посты короче N символов

# ── Сервер ────────────────────────────────────────────────────────────────────
MODE=webhook                 # webhook (Railway) | polling (локально)
WEBHOOK_URL=                 # https://your-app.up.railway.app  (Railway даёт автоматически)
